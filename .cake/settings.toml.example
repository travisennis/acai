# Example cake settings
# Copy to .cake/settings.toml and customize
# Alternatively, place in ~/.config/cake/settings.toml for global settings
# Project settings override global settings for models with the same name

# Name of the model to use when --model is not specified.
# Must refer to a name in one of the [[models]] entries below.
default_model = "zen"

[[models]]
# Required: unique name for this model (lowercase, alphanumeric, hyphens only)
name = "zen"
# Required: model identifier
model = "glm-5"
# Required: base URL for the API endpoint
base_url = "https://opencode.ai/zen/go/v1/"
# Required: environment variable containing the API key
api_key_env = "OPENCODE_ZEN_API_TOKEN"
# Optional: "chat_completions" or "responses"
# api_type = "chat_completions"
# Optional: sampling temperature
# temperature = 0.8
# Optional: nucleus sampling parameter (alternative to temperature)
# top_p = 0.9
# Optional: maximum output tokens
# max_output_tokens = 8000
# Optional: provider routing hints
# providers = []

[[models]]
name = "claude"
model = "anthropic/claude-3-sonnet"
base_url = "https://openrouter.ai/api/v1/"
api_key_env = "OPENROUTER_API_KEY"
api_type = "responses"
# temperature = 0.7
# top_p = 0.9
# max_output_tokens = 8000
# providers = []
